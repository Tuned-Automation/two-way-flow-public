# Copy this file to `.env` and fill in your keys.
# `.env` is gitignored and is loaded by the main process via dotenv.
# Never expose these to the renderer.
#
# All API keys can also be set in-app via Settings → Setup. Values
# saved in Settings take precedence over env vars; an empty Settings
# slot falls back to the matching env var below.

GEMINI_API_KEY=
DEEPGRAM_API_KEY=

# Placeholders for upcoming providers (Phase 2 — provider abstraction).
# Settings → Setup already accepts these slots; the providers themselves
# aren't wired up yet.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
